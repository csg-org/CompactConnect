{
  "name": "compact-connect",
  "version": "1.0.0",
  "type": "commonjs",
  "description": "NodeJS lambdas for CompactConnect",
  "resolutions": {
    "fast-xml-parser": "5.7.0",
    "postcss": "8.5.10"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "lint:fix": "eslint '**/*.ts' --fix",
