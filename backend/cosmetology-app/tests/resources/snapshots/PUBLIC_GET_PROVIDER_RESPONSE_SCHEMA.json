            "type": "string"
          },
          "dateOfExpiration": {
            "format": "date",
            "pattern": "^[12]{1}[0-9]{3}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])$",
            "type": "string"
          },
          "licenseNumber": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
