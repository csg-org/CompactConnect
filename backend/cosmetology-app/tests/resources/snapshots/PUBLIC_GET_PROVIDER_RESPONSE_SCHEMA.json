    "licenses": {
      "description": "Sanitized home-state license rows (LicensePublicResponseSchema)",
      "items": {
        "properties": {
          "type": {
            "enum": [
              "license"
            ],
            "type": "string"
          },
          "compact": {
            "enum": [
              "cosm"
            ],
            "type": "string"
          },
          "jurisdiction": {
            "enum": [
              "al",
              "az",
              "co",
              "ks",
              "ky",
              "md",
              "oh",
              "tn",
              "va",
              "wa"
            ],
            "type": "string"
          },
