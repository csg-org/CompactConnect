{
  "name": "ia-vuejs-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "serve": "yarn audit:dependencies && yarn lint --no-fix && vue-cli-service serve",
    "build": "yarn audit:dependencies && vue-cli-service build",
    "test:unit:all": "export NODE_OPTIONS=--openssl-legacy-provider && yarn lint --no-fix && vue-cli-service test:unit 'src/**/*.spec.ts'",
    "test:unit": "export NODE_OPTIONS=--openssl-legacy-provider && yarn lint --no-fix && vue-cli-service test:unit",
    "test:unit:coverage": "export NODE_OPTIONS=--openssl-legacy-provider && nyc vue-cli-service test:unit 'src/**/*.spec.ts' --reporter progress",
    "test:e2e": "TZ=America/Denver vue-cli-service test:e2e",
    "lint": "vue-cli-service lint",
    "audit:dependencies": "/bin/bash -c 'yarn audit --groups dependencies --level moderate; [[ $? -ge 4 ]] && exit 1 || exit 0'"
  },
